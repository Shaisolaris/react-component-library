{
  "name": "@solaris/ui",
  "version": "1.0.0",
  "description": "Production-ready headless React component library with TypeScript, accessibility, composable APIs, and CSS variable theming",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "scripts": {
    "dev": "tsx watch src/demo/server.ts",
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit"
  },
  "peerDependencies": {
    "react": "^18.0.0",
    "react-dom": "^18.0.0"
  },
  "dependencies": {
    "clsx": "^2.1.0"
  },
  "devDependencies": {
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@types/node": "^20.12.0",
    "typescript": "^5.4.0",
    "tsup": "^8.0.0",
    "tsx": "^4.10.0"
  },
  "keywords": [
    "react",
    "components",
    "ui",
    "headless",
    "typescript",
    "hooks",
    "accessible",
    "design-system"
  ],
  "author": "Shai A",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Shaisolaris/react-component-library.git"
  },
  "homepage": "https://github.com/Shaisolaris/react-component-library#readme"
}